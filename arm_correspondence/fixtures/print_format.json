  "html": "<style>\r\n  body { direction: rtl; font-family: Arial, sans-serif; padding: 20px; }\r\n  .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 3px solid #1F3864; padding-bottom: 15px; }\r\n  .logo { height: 90px; object-fit: contain; }\r\n  .company-info { text-align: center; }\r\n  .company-name { font-size: 22px; font-weight: bold; color: #1F3864; }\r\n  .meta-table { width: 100%; border-collapse: collapse; margin: 20px 0; }\r\n  .meta-table td { padding: 8px 12px; border: 1px solid #ccc; font-size: 14px; text-align: right; }\r\n  .meta-label { background: #1F3864; color: white; font-weight: bold; width: 150px; }\r\n  .letter-body { margin: 30px 0; line-height: 2; font-size: 15px; text-align: right; }\r\n  .attach-title { background: #2E75B6; color: white; padding: 6px 12px; font-weight: bold; margin-top: 30px; text-align: right; }\r\n  .attach-table { width: 100%; border-collapse: collapse; margin-top: 5px; }\r\n  .attach-table th { background: #D6E4F0; padding: 8px; border: 1px solid #ccc; font-size: 13px; }\r\n  .attach-table td { padding: 8px; border: 1px solid #ccc; font-size: 13px; text-align: right; }\r\n  .footer { margin-top: 60px; border-top: 2px solid #1F3864; display: flex; justify-content: space-between; padding-top: 15px; }\r\n</style>\r\n\r\n<div class=\"header\">\r\n  <img class=\"logo\" src=\"/files/logo and name 1.jpeg\" alt=\"ARM Logo\" onerror=\"this.src='/assets/frappe/images/frappe-framework-logo.svg'; this.style.height='40px';\">\r\n  <div class=\"company-info\">\r\n    <div class=\"company-name\">شركة أرم للعمارة والبناء</div>\r\n    <div style=\"color: #2E75B6; font-style: italic;\">ARM Architecture & Construction</div>\r\n  </div>\r\n  <div style=\"text-align: left; font-size: 13px;\">\r\n    <div><b>الرقم الإشاري:</b> {{ doc.name }}</div>\r\n    <div><b>التاريخ:</b> {{ doc.letter_date }}</div>\r\n  </div>\r\n</div>\r\n\r\n<table class=\"meta-table\">\r\n  <tr>\r\n    <td class=\"meta-label\">نوع المراسلة</td>\r\n    <td>{{ doc.letter_type }}</td>\r\n    <td class=\"meta-label\">درجة الأهمية</td>\r\n    <td style=\"font-weight: bold; color: {% if doc.priority in ['عاجلة','مهمة'] %}red{% else %}black{% endif %};\">{{ doc.priority }}</td>\r\n  </tr>\r\n  <tr>\r\n    <td class=\"meta-label\">من القسم</td>\r\n    <td>{{ doc.sender_department }}</td>\r\n    <td class=\"meta-label\">إلى القسم</td>\r\n    <td>{{ doc.recipient_department }}</td>\r\n  </tr>\r\n  <tr>\r\n    <td class=\"meta-label\">اسم المُرسِل</td>\r\n    <td>{{ doc.sender_name }}</td>\r\n    <td class=\"meta-label\">اسم المستلِم</td>\r\n    <td>{{ doc.recipient_name or 'السيد رئيس القسم' }}</td>\r\n  </tr>\r\n</table>\r\n\r\n<h3 style=\"text-align: center; text-decoration: underline; color: #1F3864; margin-top: 20px; margin-bottom: 20px;\">\r\n  الموضوع: {{ doc.letter_title }}\r\n</h3>\r\n\r\n<div class=\"letter-body\">\r\n  {{ doc.letter_body }}\r\n</div>\r\n\r\n{% if doc.attachments %}\r\n<div class=\"attach-title\">المرفقات والوثائق المصاحبة فحوى الرسالة</div>\r\n<table class=\"attach-table\">\r\n  <thead>\r\n    <tr>\r\n      <th>ت</th>\r\n      <th>رقم المرفق</th>\r\n      <th>الوصف وفحوى الصورة</th>\r\n      <th>النوع</th>\r\n      <th>ملاحظات</th>\r\n    </tr>\r\n  </thead>\r\n  <tbody>\r\n    {% for row in doc.attachments %}\r\n    <tr>\r\n      <td>{{ loop.index }}</td>\r\n      <td>{{ row.attachment_number or '-' }}</td>\r\n      <td>{{ row.attachment_description }}</td>\r\n      <td>{{ row.attachment_type }}</td>\r\n      <td>{{ row.attachment_notes or '-' }}</td>\r\n    </tr>\r\n    {% endfor %}\r\n  </tbody>\r\n</table>\r\n{% endif %}\r\n\r\n<div class=\"footer\">\r\n  <div><b>توقيع منشئ الرسالة:</b> _________________</div>\r\n  <div style=\"text-align: left;\">\r\n    <div><b>الاسم:</b> {{ doc.sender_name }}</div>\r\n    <div>\r\n      <b>الصفة:</b> \r\n      {% set designation = frappe.db.get_value(\"Employee\", {\"user_id\": doc.owner}, \"designation\") %}\r\n      {{ designation or \"\" }}\r\n    </div>\r\n  </div>\r\n</div>",
